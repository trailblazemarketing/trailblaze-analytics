# Trailblaze Analytics — env template
# Copy to .env and fill in. Never commit .env.
#
# ----------------------------------------------------------------------
# DATABASE — used by both the Python backend (Alembic / parser / Beacon /
# narratives runner) and the Next.js app via lib/db.ts pg pool.
# ----------------------------------------------------------------------
# Local dev default:
# DATABASE_URL=postgresql+psycopg://trailblaze:trailblaze@localhost:5432/trailblaze
#
# Production (Neon / any Postgres 16+) — the Python tools accept the
# `postgresql+psycopg://` scheme; Node's pg package needs plain
# `postgresql://` or `postgres://`. Neon connection strings arrive as
# `postgresql://…?sslmode=require` which both sides accept.
DATABASE_URL=

# ----------------------------------------------------------------------
# ANTHROPIC — used by the Python parser (src/trailblaze/parser/llm.py)
# and the narrative extractor (src/trailblaze/narratives/extractor.py).
# Not consumed by Node; Vercel doesn't strictly need it but setting it
# is harmless.
# ----------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Parser model / version tags. Opus for parser, Haiku for narratives
# (see src/trailblaze/narratives/extractor.py for the default).
PARSER_MODEL=claude-opus-4-7
PARSER_VERSION=2.0.0

# Throttling knobs for parallel LLM fan-out (both default-safe):
# TRAILBLAZE_LLM_PRE_CALL_DELAY_S=0
# TRAILBLAZE_LLM_MAX_RETRIES=2

# ----------------------------------------------------------------------
# NEXT.JS APP (frontend) — variables Node reads at runtime. `NEXT_PUBLIC_*`
# values are exposed to the browser; everything else stays server-side.
# ----------------------------------------------------------------------
# Canonical site URL for absolute links generated server-side.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Brief calls it APP_URL — unused in current code but harmless if set.
# NEXT_PUBLIC_APP_URL=https://insight.trailblaze-marketing.com

# Legacy Supabase scaffolding — currently stubbed. Phase 7 swap will
# populate these. Leave empty to use the demo-grade tb_session cookie auth.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# AUTH_ALLOWED_EMAILS=someone@example.com,other@example.com

# ----------------------------------------------------------------------
# PATHS / misc
# ----------------------------------------------------------------------
PDF_INBOX_DIR=./pdfs

# Gmail ingestion — only needed when running trailblaze-scrape-gmail.
# Points at the Google OAuth client_secrets.json (see secrets/ locally).
# GMAIL_CREDENTIALS_PATH=./secrets/gmail-credentials.json

# Skip auto matview refresh during bulk ingest (optional perf knob).
# TRAILBLAZE_SKIP_MATVIEW_REFRESH=1

# Session-signing secret. NOT currently used by the tb_session cookie
# auth (tokens are random 32-byte hex stored server-side). Set it
# anyway in Vercel so a future signed-cookie migration is a flag flip.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# SESSION_SECRET=
