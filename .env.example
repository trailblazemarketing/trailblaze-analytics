# Trailblaze Analytics — local env template
# Copy to .env and fill in. Never commit .env.

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg://trailblaze:trailblaze@localhost:5432/trailblaze

# Anthropic (parser)
ANTHROPIC_API_KEY=

# Parser config
PARSER_MODEL=claude-opus-4-7
PARSER_VERSION=2.0.0

# Paths
PDF_INBOX_DIR=./pdfs
